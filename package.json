{
  "name": "@hellacardgames/runo",
  "version": "0.2.0",
  "description": "A TypeScript library implementing the RUNO card game.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Richard Gieg"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hellacardgames/runo.git"
  },
  "bugs": {
    "url": "https://github.com/hellacardgames/runo/issues"
  },
  "homepage": "https://github.com/hellacardgames/runo#readme",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
